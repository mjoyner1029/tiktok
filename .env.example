# ── Core ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | staging | production
DEBUG=true

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_OR_APP_WILL_NOT_START
REQUIRE_HTTPS=false  # MUST be true in production
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tiktok_engine
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local  # local | s3
STORAGE_LOCAL_ROOT=./storage
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=  # For MinIO / Cloudflare R2

# ── Anthropic / Claude ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_TIMEOUT=120

# ── Stripe Billing ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_PRICE_IDS={"starter": "price_xxx", "creator_pro": "price_yyy", "agency": "price_zzz"}

# ── FFmpeg ───────────────────────────────────────────────────────────────
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
RENDER_OUTPUT_DIR=./renders

# ── Whisper (transcription) ──────────────────────────────────────────────
WHISPER_MODEL=base  # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu  # cpu | cuda
WHISPER_CACHE_MODELS=true

# ── Celery ───────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Limits ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
MAX_CLIP_DURATION_SEC=300
MAX_OUTPUT_DURATION_SEC=180
MAX_REFERENCES_PER_PROJECT=5
MAX_RAW_CLIPS_PER_PROJECT=10

# ── Export ───────────────────────────────────────────────────────────────
EXPORT_WIDTH=1080
EXPORT_HEIGHT=1920
EXPORT_FPS=30
EXPORT_VIDEO_BITRATE=8M
EXPORT_AUDIO_BITRATE=192k

# ── Observability ────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
ENABLE_METRICS=true
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
JSON_LOGS=false  # true for production

# ── Content Safety ───────────────────────────────────────────────────────
ENABLE_CONTENT_MODERATION=false
MAX_VIDEO_DURATION_SEC=600
ALLOWED_VIDEO_FORMATS=["mp4", "mov", "avi", "mkv", "webm"]

# ── Performance ──────────────────────────────────────────────────────────
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
MAX_CONCURRENT_RENDERS=3
